model Clients {
    id          Int      @default(autoincrement()) @id
    userId      Int
    user      Users     @relation(fields: [userId], references: [id])
    clientName  String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    deletedAt   DateTime?
    status      Int      @default(1)
    chats       Chats[]
}