model Message {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text // para mensajes largos
  chatId     Int
  chat       Chat     @relation(fields: [chatId], references: [id])
  senderId   Int      // ID de quien envía el mensaje
  senderType String   // @db.VarChar(10) - 'client' o 'driver'
  readAt     DateTime? // para saber si ya fue leído
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  status     Int      @default(1) // 1: enviado, 2: entregado, 3: leído, etc.
  
  @@index([chatId])
  @@index([createdAt])
  @@index([senderId, senderType])
}